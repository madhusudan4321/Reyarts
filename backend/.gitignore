# ── Backend .gitignore ──────────────────────────────────────────

# Dependencies
node_modules/

# Environment variables (NEVER push these)
.env
.env.local
.env.development
.env.production

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build output
dist/
build/

# OS files
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/

# Package manager locks (optional — keep package-lock.json but ignore yarn/pnpm)
yarn.lock
pnpm-lock.yaml

# ── Frontend .gitignore ──────────────────────────────────────────

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Dependencies
node_modules

# Build output
dist
dist-ssr

# Environment variables (NEVER push — contains secrets)
.env
.env.local
.env.development
.env.production
# .env.example is SAFE to push (template with no real secrets)

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
